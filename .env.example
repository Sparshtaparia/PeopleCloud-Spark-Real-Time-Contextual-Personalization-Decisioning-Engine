# --- Frontend (Next.js) ---

# Database — use either Supabase PostgreSQL (primary) or SQLite fallback
# Supabase (pooler for runtime, direct for migrations)
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres"
# SQLite fallback (comment out Supabase URLs and uncomment below to switch)
# DATABASE_URL="file:./dev.db"

NEXTAUTH_SECRET="<generate-a-random-secret>"
NEXTAUTH_URL="http://localhost:3000"
GEMINI_API_KEY="<your-gemini-api-key>"

# --- Backend (FastAPI) ---

SUPABASE_URL="https://<project>.supabase.co"
SUPABASE_KEY="<your-supabase-anon-key>"
# DATABASE_URL can reuse the same Supabase pooler URL above
# GEMINI_API_KEY can reuse the same key above
